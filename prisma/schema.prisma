// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid())
  personnelId String    @unique @map("personnel_id")
  password    String
  role        Role      @default(STAFF)
  isActive    Boolean   @default(true) @map("is_active")
  lastLogin   DateTime? @map("last_login")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("User")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  head        String   // Head Surgeon/Doctor
  staffCount  Int      @default(0) @map("staff_count")
  occupancy   Int      @default(0) // Percentage 0-100
  status      String   // Optimal, High Load, Critical, Available
  color       String   // e.g., rose, blue, indigo, red
  wards       Ward[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

model Ward {
  id           String   @id @default(uuid())
  name         String   @unique
  departmentId String   @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])
  totalBeds    Int      @default(0) @map("total_beds")
  color        String   // e.g., rose, blue, amber
  beds         Bed[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("wards")
}

model Bed {
  id        String   @id @default(uuid())
  bedNumber String   @map("bed_number")
  wardId    String   @map("ward_id")
  ward      Ward     @relation(fields: [wardId], references: [id])
  status    String   // Occupied, Available, Cleaning
  patientId String?  @map("patient_id") // e.g., PT-4105
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([wardId, bedNumber])
  @@map("beds")
}

model OperationTheatre {
  id           String   @id @default(uuid())
  theatreId    String   @unique @map("theatre_id") // e.g., OT-01
  status       String   // Active Surgery, Ready, Cleaning
  doctor       String?  @map("lead_doctor") // e.g., Dr. Elena Gilbert
  patient      String?  @map("patient_id")
  procedure    String?  @map("procedure_name")
  progress     Int      @default(0)
  equipment    String   @default("Good") // Excellent, Ready, Observation
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("operation_theatres")
}

model LaboratoryTest {
  id        String   @id @default(uuid())
  testId    String   @unique @map("test_id") // e.g., LAB-X1
  name      String
  type      String   // e.g., Hematology, Biochemistry, Radiology
  time      String   // e.g., 2 Hours, 24 Hours
  status    String   // Critical Priority, Urgent, Routine, Scheduled
  price     String   // e.g., ₹850
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("laboratory_tests")
}

enum Role {
  ADMIN
  DOCTOR 
  NURSE
  STAFF
  LAB_TECHNICIAN
  PHARMACIST
}

// ── Human Capital ─────────────────────────────────────────────────────────────

model Patient {
  id           String    @id @default(uuid())
  patientId    String    @unique @map("patient_id") // e.g., PT-4105
  name         String
  age          Int
  gender       String    // Male, Female, Other
  bloodGroup   String    @map("blood_group")
  phone        String
  address      String?
  condition    String    // Stable, Critical, Recovery, etc.
  ward         String?
  admittedOn   DateTime? @map("admitted_on")
  dischargedOn DateTime? @map("discharged_on")
  status       String    @default("Inpatient") // Inpatient, Outpatient, Discharged
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  appointments  Appointment[]
  billingRecords BillingRecord[]
  ehrRecords    EHRRecord[]

  @@map("patients")
}

model Doctor {
  id           String   @id @default(uuid())
  doctorId     String   @unique @map("doctor_id") // e.g., DR-001
  name         String
  specialty    String
  departmentId String?  @map("department_id")
  phone        String
  email        String?  @unique
  experience   Int      @default(0) // Years of experience
  status       String   @default("On Duty") // On Duty, Off Duty, On Leave
  schedule     String?  // e.g., Mon-Fri
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("doctors")
}

model MedicalStaff {
  id          String   @id @default(uuid())
  staffId     String   @unique @map("staff_id") // e.g., NRS-201
  name        String
  role        String   // Nurse, Paramedic, Technician, etc.
  department  String
  phone       String
  shift       String   // Morning, Evening, Night
  status      String   @default("On Duty") // On Duty, Off Duty, On Leave
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("medical_staff")
}

model NonMedicalStaff {
  id          String   @id @default(uuid())
  staffId     String   @unique @map("staff_id") // e.g., ADM-301
  name        String
  designation String   // Admin, Housekeeping, Security, IT, etc.
  department  String
  phone       String
  shift       String   // Morning, Evening, Night
  status      String   @default("Active") // Active, Inactive, On Leave
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("non_medical_staff")
}

// ── Clinical Operations ───────────────────────────────────────────────────────

model Appointment {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id") // e.g., APT-1001
  patientId     String   @map("patient_id")
  patient       Patient  @relation(fields: [patientId], references: [id])
  doctorId      String   @map("doctor_id")
  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  date          DateTime
  timeSlot      String   @map("time_slot") // e.g., 10:00 AM
  type          String   // Consultation, Follow-up, Emergency, Procedure
  status        String   @default("Scheduled") // Scheduled, Completed, Cancelled, No-Show
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("appointments")
}

model BillingRecord {
  id          String   @id @default(uuid())
  billId      String   @unique @map("bill_id") // e.g., BILL-5001
  patientId   String   @map("patient_id")
  patient     Patient  @relation(fields: [patientId], references: [id])
  amount      Float
  paidAmount  Float    @default(0) @map("paid_amount")
  category    String   // Consultation, Surgery, Lab, Pharmacy, Room
  status      String   @default("Pending") // Pending, Paid, Partial, Waived
  paymentMode String?  @map("payment_mode") // Cash, Card, Insurance, UPI
  issuedOn    DateTime @default(now()) @map("issued_on")
  dueDate     DateTime? @map("due_date")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("billing_records")
}

model EHRRecord {
  id          String   @id @default(uuid())
  ehrId       String   @unique @map("ehr_id") // e.g., EHR-9001
  patientId   String   @map("patient_id")
  patient     Patient  @relation(fields: [patientId], references: [id])
  diagnosis   String
  prescription String?
  notes       String?
  vitals      String?  // JSON string: { bp, pulse, temp, spo2 }
  doctorName  String   @map("doctor_name")
  visitDate   DateTime @map("visit_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ehr_records")
}

// ── Supply Chain ──────────────────────────────────────────────────────────────

model BloodInventory {
  id          String   @id @default(uuid())
  group       String   @unique // O+, A-, etc.
  units       Int      @default(0)
  status      String   // Optimal, Low, Critical
  lastStocked DateTime @default(now()) @map("last_stocked")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blood_inventory")
}

model PharmacyItem {
  id          String   @id @default(uuid())
  itemId      String   @unique @map("item_id") // e.g., PHARM-902
  name        String
  category    String   // e.g., Antibiotic, Analgesic
  stock       Int      @default(0)
  unit        String   // e.g., Tablets, Vials
  status      String   // In Stock, Low Stock, Out of Stock
  price       String
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pharmacy_items")
}

model Consumable {
  id          String   @id @default(uuid())
  itemId      String   @unique @map("item_id") // e.g., CON-402
  name        String
  category    String   // e.g., Surgical, PPE, General
  stock       Int      @default(0)
  status      String   // Optimal, Low, Critical
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("consumables")
}

model BloodDonor {
  id          String   @id @default(uuid())
  name        String
  bloodGroup  String   @map("blood_group")
  phone       String
  lastDonated DateTime? @map("last_donated")
  status      String   @default("Eligible") // Eligible, Deferred, Ineligible
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blood_donors")
}
